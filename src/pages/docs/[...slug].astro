---
import { getCollection, render } from 'astro:content';
import Layout from '@/components/Layout.astro';
import PageMeta from '@/components/PageMeta.astro';
import TOC from '@/components/TOC.astro';
import * as MdxComponents from '@/components/mdx';

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection('docs', (e) => !e.data.draft && !e.id.startsWith('_fixtures/'));
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.description} ogSlug={entry.id.replace(/\.mdx?$/, '')}>
  <PageMeta
    title={entry.data.title}
    description={entry.data.description}
    diataxis={entry.data.diataxis}
  />
  <Content components={MdxComponents} />
  <TOC slot="toc" headings={headings} />
</Layout>
