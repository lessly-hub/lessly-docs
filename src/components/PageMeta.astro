---
/**
 * Page-header meta row.
 * Sequence (spec §Page-header pattern):
 *   1. Diátaxis eyebrow label — neutral, no color.
 *   2. h1 page title.
 *   3. Lead paragraph.
 *   4. Status pill — alpha / beta / stable. Color is reserved here
 *      (the only place in the page header where color carries meaning).
 *
 * Status colors are intentionally fixed in this component:
 *   - alpha  → warning token. Signals "stub, do not rely on this".
 *   - beta   → brand-bright token. Signals "real content, not peer-reviewed".
 *   - stable → tertiary text token. Signals "peer-reviewed, low-noise".
 * No hex values — every color resolves to a Lessly design token.
 */
interface Props {
  title: string;
  description: string;
  diataxis: 'tutorial' | 'how-to' | 'explanation' | 'reference';
  status: 'alpha' | 'beta' | 'stable';
}

const { title, description, diataxis, status } = Astro.props;

const diataxisLabel: Record<Props['diataxis'], string> = {
  tutorial: 'Tutorial',
  'how-to': 'How-to',
  explanation: 'Explanation',
  reference: 'Reference',
};

const statusPillClass: Record<Props['status'], string> = {
  alpha:
    'border-[var(--color-border-warning)] bg-[var(--color-bg-warning-subtle)] text-[var(--color-text-warning)]',
  beta:
    'border-[var(--color-border-brand)] bg-[var(--color-bg-brand-subtle)] text-[var(--color-text-brand-bright)]',
  stable:
    'border-[var(--color-border-subtle)] bg-[var(--color-bg-surface)] text-[var(--color-text-tertiary)]',
};
---

<header class="mb-10">
  <div
    class="mb-3 text-xs font-medium uppercase tracking-[0.04em] text-[var(--color-text-tertiary)]"
  >
    {diataxisLabel[diataxis]}
  </div>
  <h1 class="mb-3 text-4xl font-extrabold leading-[1.1] tracking-tight text-[var(--color-text-primary)]">
    {title}
  </h1>
  <p class="text-lg text-[var(--color-text-secondary)] leading-[1.5]">{description}</p>
  <div class="mt-4">
    <span
      class:list={[
        'inline-flex items-center rounded-sm border px-1.5 py-0.5 font-mono text-[0.6875rem] uppercase tracking-wide',
        statusPillClass[status],
      ]}
    >
      {status}
    </span>
  </div>
</header>
