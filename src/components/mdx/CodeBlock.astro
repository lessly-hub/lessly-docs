---
/**
 * CodeBlock — pre-tokenized Shiki code block.
 *
 * Server-side: tokenizes `code` at build time via the shared highlighter
 * (`@/lib/shiki/highlighter`). Emits dual themes (`github-dark` default +
 * `github-light` under `.light`).
 *
 * Variants:
 *   - `default`  — language pill + filename pill + copy button.
 *   - `diff`     — `+` green tint, `-` red tint, NO language pill.
 *   - `terminal` — `$` prompt dimmed, NO copy button, NO filename pill.
 *
 * Highlights: `highlightLines="1,3-5"` → those lines get a brand-subtle wash.
 * Line numbers: `showLineNumbers` (default false).
 *
 * Long lines: horizontal scroll, no wrap (spec §Component contracts).
 */
import Copy from 'lucide/dist/esm/icons/copy.mjs';
import Check from 'lucide/dist/esm/icons/check.mjs';
import { renderIcon, type LucideIcon } from '@/lib/icon';
import { renderCodeHtml } from '@/lib/shiki/highlighter';

interface Props {
  code: string;
  lang?: string;
  filename?: string;
  highlightLines?: string;
  showLineNumbers?: boolean;
  variant?: 'default' | 'diff' | 'terminal';
}

const {
  code,
  lang = 'text',
  filename,
  highlightLines,
  showLineNumbers = false,
  variant = 'default',
} = Astro.props;

const html = renderCodeHtml({
  code,
  lang,
  variant,
  highlightLines,
  showLineNumbers,
});

const showLangPill = variant === 'default' && lang && lang !== 'text';
const showFilenamePill = variant !== 'terminal' && Boolean(filename);
const showCopyButton = variant !== 'terminal';

const copyIcon = renderIcon(Copy as unknown as LucideIcon, {
  size: 14,
  class: 'lessly-code__icon-copy',
});
const checkIcon = renderIcon(Check as unknown as LucideIcon, {
  size: 14,
  class: 'lessly-code__icon-check hidden',
});
---

<figure
  class:list={[
    'lessly-code group relative my-6 overflow-hidden rounded-md border border-[var(--color-border-subtle)] bg-[var(--color-bg-elevated)]',
    `lessly-code--${variant}`,
  ]}
>
  {(showFilenamePill || showLangPill || showCopyButton) && (
    <header
      class="flex h-9 items-center justify-between border-b border-[var(--color-border-subtle)] bg-[var(--color-bg-sunken)] px-4 text-xs text-[var(--color-text-tertiary)]"
    >
      <div class="flex min-w-0 items-center gap-2">
        {showFilenamePill && (
          <span
            class="truncate font-mono text-[0.75rem] text-[var(--color-text-secondary)]"
          >
            {filename}
          </span>
        )}
        {showLangPill && (
          <span
            class="rounded-sm bg-[var(--color-bg-surface)] px-1.5 py-0.5 font-mono text-[0.6875rem] uppercase tracking-wide text-[var(--color-text-tertiary)]"
          >
            {lang}
          </span>
        )}
      </div>
      {showCopyButton && (
        <button
          type="button"
          class="lessly-code__copy flex items-center gap-1 rounded-sm px-1.5 py-0.5 text-[var(--color-text-tertiary)] transition-colors hover:bg-[var(--color-bg-surface)] hover:text-[var(--color-text-primary)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand-bright)]"
          data-copy-label="Copy"
          data-copied-label="Copied"
          aria-label="Copy code to clipboard"
        >
          <span class="lessly-code__icon" set:html={copyIcon} />
          <span class="lessly-code__icon" set:html={checkIcon} />
          <span class="lessly-code__copy-label">Copy</span>
        </button>
      )}
    </header>
  )}
  <div class="lessly-code__scroll overflow-x-auto" set:html={html} />
  {/* Raw source for the copy button — never rendered. */}
  <template class="lessly-code__source">{code}</template>
</figure>

<!--
  Styles for .lessly-code live in src/styles/global.css (not here).
  Reason: fenced ``` blocks are rendered as raw HTML by src/lib/rehype/code.ts
  without mounting this component, so any `<style is:global>` block here would
  never bundle on pages that only use fenced blocks. Keep CSS global.
-->
<script>
  // Vanilla TS — ~20 lines, no framework. Wires up every CodeBlock on the page.
  function wireCopyButtons() {
    const blocks = document.querySelectorAll<HTMLElement>('.lessly-code');
    blocks.forEach((block) => {
      const button = block.querySelector<HTMLButtonElement>('.lessly-code__copy');
      const source = block.querySelector<HTMLTemplateElement>('template.lessly-code__source');
      if (!button || !source || button.dataset.wired === '1') return;
      button.dataset.wired = '1';
      const copyIcon = button.querySelector<HTMLElement>('.lessly-code__icon-copy')?.parentElement;
      const checkIcon = button.querySelector<HTMLElement>('.lessly-code__icon-check')?.parentElement;
      const label = button.querySelector<HTMLElement>('.lessly-code__copy-label');
      const copiedLabel = button.dataset.copiedLabel ?? 'Copied';
      const copyLabel = button.dataset.copyLabel ?? 'Copy';
      button.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(source.innerHTML);
          if (label) label.textContent = copiedLabel;
          if (copyIcon) copyIcon.classList.add('hidden');
          if (checkIcon) checkIcon.classList.remove('hidden');
          window.setTimeout(() => {
            if (label) label.textContent = copyLabel;
            if (copyIcon) copyIcon.classList.remove('hidden');
            if (checkIcon) checkIcon.classList.add('hidden');
          }, 2000);
        } catch {
          /* clipboard unavailable */
        }
      });
    });
  }
  wireCopyButtons();
  document.addEventListener('astro:page-load', wireCopyButtons);
</script>
