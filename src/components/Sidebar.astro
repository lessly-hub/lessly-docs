---
/**
 * Desktop sidebar (scoped-tab navigation).
 *
 * Renders ONLY the active section's pages as a flat list — the section is
 * chosen by the current path (`activeGroupId`), falling back to the first
 * group. Section switching lives in the header tabs; the full multi-section
 * tree lives in the mobile drawer (MobileNav). 280px, sticky under the 56px
 * header, scrollable. No collapse state, no client script.
 */
import { getNav, activeGroupId } from '@/lib/nav';

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;
const groups = await getNav();

// Normalize so the active test matches regardless of trailing slash.
const normalizedPath = currentPath.replace(/\/$/, '');
const activeId = activeGroupId(normalizedPath);
const activeGroup = groups.find((g) => g.id === activeId) ?? groups[0];
---

<aside
  class="sticky top-[56px] hidden h-[calc(100vh-56px)] w-[280px] shrink-0 overflow-y-auto border-r border-[var(--color-border-subtle)] lg:block"
  aria-label="Section navigation"
>
  {activeGroup && (
    <nav class="px-4 py-6">
      <ul class="m-0 list-none p-0">
        {activeGroup.items.map((item) => {
          const active = normalizedPath === item.href;
          return (
            <li>
              <a
                href={item.href}
                aria-current={active ? 'page' : undefined}
                class:list={[
                  'flex h-8 items-center gap-2 rounded-md px-2 py-3 text-sm no-underline transition-colors',
                  active
                    ? 'bg-[var(--color-bg-elevated)] text-[var(--color-text-primary)]'
                    : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]',
                ]}
              >
                <span class="flex-1 truncate">{item.title}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  )}
</aside>
