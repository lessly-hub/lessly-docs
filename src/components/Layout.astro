---
import '@/styles/global.css';
import Header from './Header.astro';
import Sidebar from './Sidebar.astro';
import MobileNav from './MobileNav.astro';
import Search from './Search.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import Footer from './Footer.astro';

// Preload the four above-the-fold woff2 faces so they beat the 100ms
// font-display:optional block period on cold loads. Measured: without
// preload, FCP ~376ms and Inter ready ~478ms → fallback wins → users
// see Arial-with-Inter-metrics on first visit and real Inter on
// refresh (no CLS, but glyph shape changes between sessions). Preload
// puts the fonts in flight at HTML-parse time so the cold-load paint
// uses real Inter too.
//
// LCP impact: this site's LCP is text (H1 Inter 800), not an image —
// the older "preload hurts LCP" warning applied to image-LCP pages,
// not here.
import interWeight400 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import interWeight600 from '@fontsource/inter/files/inter-latin-600-normal.woff2?url';
import interWeight800 from '@fontsource/inter/files/inter-latin-800-normal.woff2?url';
import firaMono400 from '@fontsource/fira-mono/files/fira-mono-latin-400-normal.woff2?url';

interface Props {
  title: string;
  description?: string;
  /** Slug used to build the per-page OG image URL (e.g. `get-started/install`). */
  ogSlug?: string;
  /** When true, render the page without sidebar/breadcrumbs/prose chrome (homepage, 404). */
  bare?: boolean;
}

const SITE = 'https://docs.lessly.com';
const { title, description = 'Lessly documentation.', ogSlug, bare = false } = Astro.props;
const currentPath = Astro.url.pathname;
const canonical = new URL(currentPath, SITE).toString();
const ogImage = ogSlug
  ? `${SITE}/og/${ogSlug}.png`
  : `${SITE}/og/default.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      // Theme bootstrap. MUST run before any CSS to avoid flash.
      // Precedence: lessly_theme cookie > local time (dark 19:00–06:59) > dark default.
      // Mirror of src/lib/theme.ts — keep the two in sync.
      (function () {
        try {
          var m = document.cookie.match(/(?:^|;\s*)lessly_theme=(dark|light)(?:;|$)/);
          var theme;
          if (m) {
            theme = m[1];
          } else {
            var h = new Date().getHours();
            theme = (h >= 19 || h < 7) ? 'dark' : 'light';
          }
          if (theme === 'light') document.documentElement.classList.add('light');
        } catch (e) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" as="font" type="font/woff2" href={interWeight400} crossorigin="anonymous" />
    <link rel="preload" as="font" type="font/woff2" href={interWeight600} crossorigin="anonymous" />
    <link rel="preload" as="font" type="font/woff2" href={interWeight800} crossorigin="anonymous" />
    <link rel="preload" as="font" type="font/woff2" href={firaMono400} crossorigin="anonymous" />
    <title>{title} — Lessly Docs</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Lessly Docs" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="flex min-h-screen flex-col bg-[var(--color-bg-primary)] text-[var(--color-text-primary)]">
    <Header currentPath={currentPath} />
    <MobileNav currentPath={currentPath} />
    {bare ? (
      <main class="flex-1">
        <slot />
      </main>
    ) : (
      <div class="mx-auto flex w-full max-w-[1400px] flex-1">
        <Sidebar currentPath={currentPath} />
        <main class="min-w-0 flex-1 px-6 py-10 lg:px-12">
          <div class="prose mx-auto">
            <Breadcrumbs currentPath={currentPath} />
            <slot />
          </div>
        </main>
        <slot name="toc" />
      </div>
    )}
    <Footer />
    <Search />
    <script>
      // Wire the Copy button on every fenced code block. The CodeBlock Astro
      // component is never mounted for fenced blocks (rehype emits raw HTML),
      // so the wire-up has to live at the Layout level to ship at all.
      import '@/lib/code-copy';
    </script>
  </body>
</html>
