{
  "name": "lessly-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:cloudflare": "next build && (test -f .next/server/middleware.js && mkdir -p .next/standalone/.next/server && cp .next/server/middleware.js .next/standalone/.next/server/middleware.js 2>/dev/null || true) && opennextjs-cloudflare build --skipNextBuild",
    "dev": "next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "theme-diagrams": "node scripts/theme-diagrams.mjs public/diagrams",
    "d2-render": "node scripts/d2-render.mjs"
  },
  "dependencies": {
    "fumadocs-core": "16.8.12",
    "fumadocs-mdx": "15.0.7",
    "fumadocs-ui": "16.8.12",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "posthog-js": "^1.374.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.93.0"
  }
}