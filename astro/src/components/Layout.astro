---
import '@/styles/global.css';
import Header from './Header.astro';
import Sidebar from './Sidebar.astro';
import Search from './Search.astro';
import Breadcrumbs from './Breadcrumbs.astro';

interface Props {
  title: string;
  description?: string;
  /** Slug used to build the per-page OG image URL (e.g. `get-started/install`). */
  ogSlug?: string;
}

const SITE = 'https://docs.lessly.com';
const { title, description = 'Lessly documentation.', ogSlug } = Astro.props;
const currentPath = Astro.url.pathname;
const canonical = new URL(currentPath, SITE).toString();
const ogImage = ogSlug
  ? `${SITE}/og/${ogSlug}.png`
  : `${SITE}/og/default.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Lessly Docs</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Lessly Docs" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link
      rel="preconnect"
      href="https://rsms.me/"
    />
    <link
      rel="stylesheet"
      href="https://rsms.me/inter/inter.css"
    />
    <script is:inline>
      // Respect prefers-color-scheme on first load. Light mode opts in via `.light` on <html>.
      try {
        const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        if (prefersLight) document.documentElement.classList.add('light');
      } catch (e) {}
    </script>
  </head>
  <body class="min-h-screen bg-[var(--color-bg-primary)] text-[var(--color-text-primary)]">
    <Header />
    <div class="mx-auto flex max-w-[1400px]">
      <Sidebar currentPath={currentPath} />
      <main class="min-w-0 flex-1 px-6 py-10 lg:px-12">
        <div class="prose mx-auto">
          <Breadcrumbs currentPath={currentPath} />
          <slot />
        </div>
      </main>
      <slot name="toc" />
    </div>
    <Search />
  </body>
</html>
