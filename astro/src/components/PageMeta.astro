---
/**
 * Page-header meta row.
 * Sequence (spec §Page-header pattern):
 *   1. Diátaxis eyebrow label — neutral, no color.
 *   2. h1 page title.
 *   3. Lead paragraph.
 *   4. Status pill row.
 */
interface Props {
  title: string;
  description: string;
  diataxis: 'tutorial' | 'how-to' | 'explanation' | 'reference';
  status?: 'alpha' | 'beta' | 'stable';
}

const { title, description, diataxis, status } = Astro.props;

const diataxisLabel: Record<Props['diataxis'], string> = {
  tutorial: 'Tutorial',
  'how-to': 'How-to',
  explanation: 'Explanation',
  reference: 'Reference',
};

const statusStyles: Record<NonNullable<Props['status']>, string> = {
  alpha: 'border-[var(--color-border-warning)] text-[var(--color-text-warning)]',
  beta: 'border-[var(--color-border-brand)] text-[var(--color-text-brand)]',
  stable: 'border-[var(--color-border-success)] text-[var(--color-text-success)]',
};
---

<header class="mb-10">
  <div
    class="mb-3 text-xs font-medium uppercase tracking-[0.04em] text-[var(--color-text-tertiary)]"
  >
    {diataxisLabel[diataxis]}
  </div>
  <h1 class="mb-3 text-4xl font-extrabold leading-[1.1] tracking-tight text-[var(--color-text-primary)]">
    {title}
  </h1>
  <p class="text-lg text-[var(--color-text-secondary)] leading-[1.5]">{description}</p>
  {status && (
    <div class="mt-4">
      <span
        class:list={[
          'inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-medium uppercase tracking-[0.04em]',
          statusStyles[status],
        ]}
      >
        {status}
      </span>
    </div>
  )}
</header>
